{
  "manifest_version": 3,
  "name": "WatchAlert Tab",
  "version": "1.1.5",
  "description": "Мониторинг зон на вкладках браузера со звуковым сигналом при устойчивых изменениях",
  "browser_specific_settings": {
    "gecko": {
      "id": "watchalert-tab@eturnercus.github",
      "strict_min_version": "121.0"
    }
  },
  "permissions": ["tabs", "windows", "storage", "unlimitedStorage", "scripting", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background/service-worker.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WatchAlert Tab"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
