{
  "manifest_version": 3,
  "name": "WatchAlert Tab",
  "version": "1.1.2",
  "description": "Мониторинг зон на вкладках браузера со звуковым сигналом при устойчивых изменениях",
  "permissions": [
    "tabs",
    "windows",
    "tabCapture",
    "storage",
    "unlimitedStorage",
    "offscreen",
    "alarms",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WatchAlert Tab"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
